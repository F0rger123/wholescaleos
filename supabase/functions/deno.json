{
  "compilerOptions": {
    "allowJs": true,
    "lib": ["deno.window", "deno.ns"],
    "strict": false
  },
  "lint": {
    "include": ["stripe-checkout", "scrape-property"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "include": ["stripe-checkout", "scrape-property"],
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "singleQuote": true,
    "proseWrap": "always"
  }
}
